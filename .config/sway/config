# Mod key
set $mod Mod4
# Terminal
set $term foot
# Monitor 1 name
set $monitor1 Virtual-1
# Monitor 2 name
set $monitor2 Virtual-2
# Target URL
set $targetURL "https://google.com"


# Monitor mapping
output $monitor1 resolution 1920x1200 position 0 0 transform 270
output $monitor2 resolution 1920x1080 position 0 1920

# Input Mapping
input "33006:33:VirtualBox_USB_Tablet" {
    map_to_output $monitor1
    calibration_matrix 0 1 0 -1 0 1
}
input "33006:51966:VirtualBox_mouse_integration" {
    map_to_output $monitor1
    calibration_matrix 0 1 0 -1 0 1
}

# Workspaces
workspace 1 output $monitor1
workspace 2 output $monitor2

assign [app_id="google-chrome"] 1
assign [class="Google-chrome"] 1

assign [app_id="foot"] 2

# Force fullscreen
for_window [app_id="google-chrome"] fullscreen enable
for_window [class="Google-chrome"] fullscreen enable

for_window [app_id="foot"] fullscreen enable

# Setup as Kiosk
# Remove window titles, borders, ...
default_border none
default_floating_border none
bar {
    mode invisible
}

# Launch the applications automatically on boot
exec google-chrome \
    --enable-features=UseOzonePlatform \
    --ozone-platform=wayland \
    --kiosk \
    --incognito \
    --disable-pinch \
    --overscroll-history-navigation=0 \
    $targetURL
exec $term

# Allow reloading the config (Mod+Shift+C) and exiting Sway (Mod+Shift+E)
bindsym $mod+Shift+c reload
bindsym $mod+Shift+e exec swaynag -t warning -m 'Exit sway?' -B 'Yes' 'swaymsg exit'

